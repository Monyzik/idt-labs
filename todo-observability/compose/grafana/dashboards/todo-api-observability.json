          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 1)",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "5xx Error Rate",
      "type": "gauge"
